apiVersion: external-secrets.io/v1beta1
kind: ExternalSecret
metadata:
  name: gitlab-runner-token
  namespace: external-secrets
spec:
  refreshInterval: 1m
  secretStoreRef:
    name: gcp-secret-manager
    kind: SecretStore
  target:
    name: gitlab-runner-token  # K8s Secret ka naam
  data:
    - secretKey: runner-token
      remoteRef:
        key: gitlab-runner-token  # GCP Secret Manager mein naam


-----------
apiVersion: helm.toolkit.fluxcd.io/v2
kind: HelmRelease
metadata:
  name: external-secrets
  namespace: external-secrets
spec:
  interval: 1m0s
  chart:
    spec:
      chart: external-secrets
      version: 0.9.x
      sourceRef:
        kind: HelmRepository
        name: external-secrets
        namespace: external-secrets
  values:
    serviceAccount:
      annotations:
        iam.gke.io/gcp-service-account: "eso-secret-accessor@project-07b9733b-5aaa-43f8-8a9.iam.gserviceaccount.com"

------------


apiVersion: v1
kind: Namespace
metadata:
   name: external-secrets
---
apiVersion: source.toolkit.fluxcd.io/v1
kind: HelmRepository
metadata:
  name: external-secrets
  namespace: external-secrets
spec:
  interval: 1m0s
  url: https://charts.external-secrets.io


--------
apiVersion: external-secrets.io/v1beta1
kind: SecretStore
metadata:
  name: gcp-secret-manager
  namespace: external-secrets
spec:
  provider:
    gcpsm:
      projectID: project-07b9733b-5aaa-43f8-8a9

